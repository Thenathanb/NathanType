rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ───────────────────────────────────────────────────
    // Public profiles are readable by anyone.
    // Only the owner may write their own document.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Friend requests subcollection
      match /friendRequests/{fromUid} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Usernames registry ───────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Test results ─────────────────────────────────────────────
    // Only the owning user may read or write their test result documents.
    match /testResults/{userId}/results/{resultId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
